# Copy to .env (never commit .env). Prefer Secret Manager in production.

STRIPE_SECRET_KEY=sk_test_...

STRIPE_WEBHOOK_SECRET=whsec_...

# OpenAI para la callable folioCloudAiComplete — clave en https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Opcional (por defecto gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini
# Base URL para API compatible con OpenAI (opcional)
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MAX_OUTPUT_TOKENS=8192
# OPENAI_TEMPERATURE=0.7
#
# IMPORTANTE: firebase.json NO sube este .env. En producción define OPENAI_API_KEY como
# variable de entorno de la función (Consola Firebase / Cloud Run). No dupliques el mismo
# nombre como env plano y como secreto o el deploy dará error "overlaps".
# Si antes usabas GEMINI_API_KEY, sustitúyela por OPENAI_API_KEY y elimina la variable antigua.



# Catalog: each value can be a Price id (price_...) or Product id (prod_...).
# If you use prod_..., set that product's default price in Stripe Dashboard.

STRIPE_PRICE_FOLIO_CLOUD_MONTHLY=price_...

STRIPE_PRICE_INK_SMALL=price_...

STRIPE_PRICE_INK_MEDIUM=price_...

STRIPE_PRICE_INK_LARGE=price_...



# Legacy: comma-separated list (optional; prefer explicit IDs above)

# STRIPE_PRICE_IDS_FOLIO_CLOUD=price_...



# Return URLs after Checkout / Billing Portal
#
# En apps de escritorio (Windows/macOS/Linux) el usuario paga en el navegador y vuelve a Folio a mano.
# Pon aquí una URL HTTPS que explique "cierra esta pestaña y vuelve a la app" (p. ej. una página tuya
# o Firebase Hosting). La app también refresca Firestore al reanudarse; estas URLs solo afectan al
# texto/página que ve el usuario tras Stripe.

BILLING_PORTAL_RETURN_URL=https://folio.app

STRIPE_CHECKOUT_SUCCESS_URL=https://folio.app

STRIPE_CHECKOUT_CANCEL_URL=https://folio.app


