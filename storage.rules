rules_version = '2';

service firebase.storage {

  match /b/{bucket}/o {

    function userDoc(uid) {
      return firestore.get(/databases/(default)/documents/users/$(uid)).data;
    }

    function folioCloudBackupOk(uid) {
      let u = userDoc(uid);
      return u.folioCloud != null
        && u.folioCloud.active == true
        && u.folioCloud.features != null
        && u.folioCloud.features.backup == true;
    }

    function folioCloudPublishOk(uid) {
      let u = userDoc(uid);
      return u.folioCloud != null
        && u.folioCloud.active == true
        && u.folioCloud.features != null
        && u.folioCloud.features.publishWeb == true;
    }

    function collabRoomDoc(roomId) {
      return firestore.get(/databases/(default)/documents/collabRooms/$(roomId)).data;
    }

    function collabMember(roomId) {
      let room = collabRoomDoc(roomId);
      return request.auth != null
        && room != null
        && (
          request.auth.uid == room.ownerUid
          || request.auth.uid in room.memberUids
        );
    }

    function collabMediaDoc(roomId, mediaId) {
      return firestore.get(/databases/(default)/documents/collabRooms/$(roomId)/media/$(mediaId)).data;
    }

    function collabMediaVisible(roomId, mediaId) {
      let media = collabMediaDoc(roomId, mediaId);
      return media != null
        && media.e2eV == 1;
    }

    // Copias cifradas: solo suscripción Folio Cloud con feature backup (servidor escribe folioCloud).
    match /users/{userId}/backups/{allPaths=**} {
      allow read, write: if request.auth != null
        && request.auth.uid == userId
        && folioCloudBackupOk(userId);
    }

    // Copias cifradas por libreta: `users/{uid}/vaults/{vaultId}/backups/*`.
    match /users/{userId}/vaults/{vaultId}/backups/{allPaths=**} {
      allow read, write: if request.auth != null
        && request.auth.uid == userId
        && folioCloudBackupOk(userId);
    }

    // Páginas HTML públicas: lectura pública; escritura solo con publicación web en el plan.
    match /published/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && folioCloudPublishOk(userId);
    }

    // Plantillas `.folio-template` comunitarias: lectura pública; escritura del dueño (cualquier auth).
    match /community-templates/{userId}/{fileName} {
      allow read: if true;
      allow delete: if request.auth != null
        && request.auth.uid == userId
        && fileName.matches('.*\\.folio-template$');
      allow create, update: if request.auth != null
        && request.auth.uid == userId
        && fileName.matches('.*\\.folio-template$')
        && request.resource.size < 1 * 1024 * 1024;
    }

    // Adjuntos multimedia cifrados E2E por sala.
    match /collab-media-e2e/{roomId}/{mediaId} {
      allow write: if collabMember(roomId)
        && request.resource.size > 0
        && request.resource.size <= 80 * 1024 * 1024;

      allow read: if collabMember(roomId)
        && collabMediaVisible(roomId, mediaId);

      allow delete: if false;
    }
  }
}
