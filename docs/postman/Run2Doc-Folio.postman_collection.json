          {
            "key": "X-Folio-App-Name",
            "value": "{{appName}}",
            "type": "text"
          },
          {
            "key": "X-Folio-App-Version",
            "value": "{{appVersion}}",
            "type": "text"
          },
          {
            "key": "X-Folio-Integration-Version",
            "value": "{{integrationVersion}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/health",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "health"
          ]
        },
        "description": "Comprueba que el bridge de Folio esta levantado en el puerto fijo y devuelve si hay una sesion activa para esta app."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Health responde 200', function () {",
              "  pm.response.to.have.status(200);",
              "});"
            ]
          }
        }
      ]
    },
