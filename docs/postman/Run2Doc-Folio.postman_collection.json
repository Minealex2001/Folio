            "value": "{{appId}}",
            "type": "text"
          },
          {
            "key": "X-Folio-App-Name",
            "value": "{{appName}}",
            "type": "text"
          },
          {
            "key": "X-Folio-App-Version",
            "value": "{{appVersion}}",
            "type": "text"
